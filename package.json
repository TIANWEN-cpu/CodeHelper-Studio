{
  "name": "codehelper",
  "version": "1.1.0",
  "description": "AI 驱动的桌面编程助手 — 集成代码编辑器、AI 对话、题库系统、知识库检索与错题追踪",
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:analyze": "node -e \"process.env.ANALYZE='1';require('child_process').execSync('electron-vite build',{stdio:'inherit',env:{...process.env,ANALYZE:'1'}})\"",
    "package": "electron-vite build && electron-builder",
    "release:patch": "node scripts/version-bump.js patch && npm run build && npm run package",
    "release:minor": "node scripts/version-bump.js minor && npm run build && npm run package",
    "release:major": "node scripts/version-bump.js major && npm run build && npm run package",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\" \"electron/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "react",
    "code-editor",
    "ai-assistant",
    "programming-practice",
    "leetcode"
  ],
  "author": "TIANWEN-cpu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TIANWEN-cpu/CodeHelper.git"
  },
  "type": "commonjs",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.33.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
